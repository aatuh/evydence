EVYDENCE_ADDR=:8080
EVYDENCE_API_KEY_PEPPER=change-me-long-random-pepper
EVYDENCE_DATABASE_URL=postgres://evydence:change-me@localhost:5432/evydence?sslmode=disable
EVYDENCE_OBJECT_STORE=filesystem
EVYDENCE_OBJECT_DIR=./tmp/objects
# For MinIO/S3, set EVYDENCE_OBJECT_STORE=minio and provide:
# EVYDENCE_S3_ENDPOINT=localhost:9000
# EVYDENCE_S3_BUCKET=evydence
# EVYDENCE_S3_ACCESS_KEY_ID=evydence
# EVYDENCE_S3_SECRET_ACCESS_KEY=change-me-change-me
# EVYDENCE_S3_USE_SSL=false
EVYDENCE_BOOTSTRAP_TENANT=Local Tenant
EVYDENCE_PRINT_BOOTSTRAP_SECRET=true
